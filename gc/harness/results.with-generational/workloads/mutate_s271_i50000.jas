    ILOAD run
    ILOAD size_tbl
    IASTORE
    IINC run 1
    BIPUSH 47
    ILOAD run
    ILOAD size_tbl
    IASTORE
    IINC run 1
    // startup: node directory (the root) of --nodes ring-linked nodes
    // node layout: [0]=next, [1]=payload
    LDC_W c_256
    ANEWARRAY
    ISTORE nodedir
    BIPUSH 0
    ISTORE prev
    BIPUSH 0
    ISTORE pos
    // build loop
    LDC_W c_256
    ISTORE ctr
loop_1:
    ILOAD ctr
    IFEQ done_2
    BIPUSH 2
    ANEWARRAY
    ISTORE node
    ILOAD prev
    BIPUSH 0
    ILOAD node
    AIASTORE
    ILOAD node
    ILOAD pos
    ILOAD nodedir
    AIASTORE
    ILOAD node
    ISTORE prev
    IINC pos 1
    IINC ctr -1
    GOTO loop_1
done_2:
    // close the ring: dir[0].next = last node
    ILOAD prev
    BIPUSH 0
    BIPUSH 0
    ILOAD nodedir
    AIALOAD
    AIASTORE
    BIPUSH 0
    ISTORE idx
    // main loop: pointer rewrites, occasional allocation
    LDC_W c_50000
    ISTORE ctr
loop_3:
    ILOAD ctr
    IFEQ done_4
    // rewrite: dir[src].next = dir[dst]
    ILOAD idx
    ILOAD dst_tbl
    IALOAD
    ILOAD nodedir
    AIALOAD
    BIPUSH 0
    ILOAD idx
    ILOAD src_tbl
    IALOAD
    ILOAD nodedir
    AIALOAD
    AIASTORE
    // occasional allocation: replace dir[src].payload (old one dies)
    ILOAD idx
    ILOAD alloc_tbl
    IALOAD
    IFEQ noalloc_5
    ILOAD idx
    ILOAD size_tbl
    IALOAD
    NEWARRAY
    BIPUSH 1
    ILOAD idx
    ILOAD src_tbl
    IALOAD
    ILOAD nodedir
    AIALOAD
    AIASTORE
noalloc_5:
    IINC idx 1
    ILOAD idx
    LDC_W c_256
    IF_ICMPEQ wrap_6
    GOTO nowrap_7
wrap_6:
    BIPUSH 0
    ISTORE idx
nowrap_7:
    IINC ctr -1
    GOTO loop_3
done_4:
    // clean termination
    HALT
.end-main
