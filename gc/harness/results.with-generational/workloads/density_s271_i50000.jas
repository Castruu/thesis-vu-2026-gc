    IASTORE
    IINC run 1
    LDC_W c_3788
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_10724
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_13317
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_7251
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_32510
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_24808
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_31166
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_18257
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_9968
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_16647
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_25314
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_9321
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_22713
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_18077
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_7691
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_907
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_10733
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    LDC_W c_10576
    ILOAD run
    ILOAD fill_tbl
    IASTORE
    IINC run 1
    // long-lived keeper array: holds the surviving fraction
    BIPUSH 64
    ANEWARRAY
    ISTORE keeper
    BIPUSH 0
    ISTORE idx
    // main loop: same allocations either kind, churn-style liveness
    LDC_W c_50000
    ISTORE ctr
loop_1:
    ILOAD ctr
    IFEQ done_2
    ILOAD idx
    ILOAD size_tbl
    IALOAD
    ISTORE length
    ILOAD idx
    ILOAD fill_tbl
    IALOAD
    ISTORE fillv
    ILOAD idx
    ILOAD kind_tbl
    IALOAD
    IFEQ valarr_3
    // reference array: every slot points at the live keeper array
    ILOAD length
    ANEWARRAY
    ISTORE tmp
    ILOAD length
    ISTORE j
fill_5:
    ILOAD j
    IFEQ filled_6
    IINC j -1
    ILOAD keeper
    ILOAD j
    ILOAD tmp
    AIASTORE
    GOTO fill_5
filled_6:
    GOTO kinddone_4
valarr_3:
    // value array: every slot gets the seeded fill value
    ILOAD length
    NEWARRAY
    ISTORE tmp
    ILOAD length
    ISTORE j
fill_7:
    ILOAD j
    IFEQ filled_8
    IINC j -1
    ILOAD fillv
    ILOAD j
    ILOAD tmp
    IASTORE
    GOTO fill_7
filled_8:
kinddone_4:
    // survival decision, as in churn
    ILOAD idx
    ILOAD surv_tbl
    IALOAD
    IFEQ skip_9
    ILOAD tmp
    ILOAD idx
    ILOAD vict_tbl
    IALOAD
    ILOAD keeper
    AIASTORE
skip_9:
    IINC idx 1
    ILOAD idx
    LDC_W c_256
    IF_ICMPEQ wrap_10
    GOTO nowrap_11
wrap_10:
    BIPUSH 0
    ISTORE idx
nowrap_11:
    IINC ctr -1
    GOTO loop_1
done_2:
    // clean termination
    HALT
.end-main
