// family=longlived
// iterations=50000
// nodes=256
// seed=9973
// size_max=64
// size_min=4
// table_size=256

.constant
    c_256 256
    c_50000 50000
.end-constant

.main
.var
    size_tbl
    root
    node
    tmp
    idx
    ctr
    run
.end-var
