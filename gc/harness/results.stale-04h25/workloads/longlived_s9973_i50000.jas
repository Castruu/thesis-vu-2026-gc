    IASTORE
    IINC run 1
    // startup: build a linked list of --nodes nodes rooted in 'root'
    // node layout: [0]=next, [1]=value-array payload
    BIPUSH 0
    ISTORE root
    BIPUSH 0
    ISTORE idx
    // build loop (head insert)
    LDC_W c_256
    ISTORE ctr
loop_1:
    ILOAD ctr
    IFEQ done_2
    BIPUSH 2
    ANEWARRAY
    ISTORE node
    ILOAD root
    BIPUSH 0
    ILOAD node
    AIASTORE
    ILOAD idx
    ILOAD size_tbl
    IALOAD
    NEWARRAY
    BIPUSH 1
    ILOAD node
    AIASTORE
    ILOAD node
    ISTORE root
    IINC idx 1
    ILOAD idx
    LDC_W c_256
    IF_ICMPEQ wrap_3
    GOTO nowrap_4
wrap_3:
    BIPUSH 0
    ISTORE idx
nowrap_4:
    IINC ctr -1
    GOTO loop_1
done_2:
    // main loop: allocate-and-drop churn against the live backdrop
    LDC_W c_50000
    ISTORE ctr
loop_5:
    ILOAD ctr
    IFEQ done_6
    ILOAD idx
    ILOAD size_tbl
    IALOAD
    NEWARRAY
    ISTORE tmp
    IINC idx 1
    ILOAD idx
    LDC_W c_256
    IF_ICMPEQ wrap_7
    GOTO nowrap_8
wrap_7:
    BIPUSH 0
    ISTORE idx
nowrap_8:
    IINC ctr -1
    GOTO loop_5
done_6:
    // clean termination
    HALT
.end-main
