    IASTORE
    IINC run 1
    // long-lived keeper array: holds the surviving fraction
    BIPUSH 64
    ANEWARRAY
    ISTORE keeper
    BIPUSH 0
    ISTORE idx
    // main loop: allocate, occasionally keep, drop otherwise
    LDC_W c_50000
    ISTORE ctr
loop_1:
    ILOAD ctr
    IFEQ done_2
    // allocate one value array of the next seeded size
    ILOAD idx
    ILOAD size_tbl
    IALOAD
    NEWARRAY
    ISTORE tmp
    // survival decision: 0 = drop (dies when tmp is next overwritten)
    ILOAD idx
    ILOAD surv_tbl
    IALOAD
    IFEQ skip_3
    ILOAD tmp
    ILOAD idx
    ILOAD vict_tbl
    IALOAD
    ILOAD keeper
    AIASTORE
skip_3:
    IINC idx 1
    ILOAD idx
    LDC_W c_256
    IF_ICMPEQ wrap_4
    GOTO nowrap_5
wrap_4:
    BIPUSH 0
    ISTORE idx
nowrap_5:
    IINC ctr -1
    GOTO loop_1
done_2:
    // clean termination
    HALT
.end-main
