// family=churn
// iterations=50000
// keeper_slots=64
// seed=1
// size_max=64
// size_min=4
// survival=0.05
// table_size=256

.constant
    c_256 256
    c_50000 50000
.end-constant

.main
.var
    size_tbl
    surv_tbl
    vict_tbl
    keeper
    tmp
    idx
    ctr
    run
.end-var
    // build allocation size table (256 entries)
    LDC_W c_256
    NEWARRAY
    ISTORE size_tbl
    BIPUSH 0
    ISTORE run
    BIPUSH 12
    ILOAD run
    ILOAD size_tbl
    IASTORE
